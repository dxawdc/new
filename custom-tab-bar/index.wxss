.tab-bar-container {
  position: fixed;
  bottom: 0;
  left: 0;
  right: 0;
  background-color: #ffffff;
  border-top: 1px solid #f3f4f6;
  border-top-left-radius: 24px;
  border-top-right-radius: 24px;
  box-shadow: 0 -10px 40px rgba(0,0,0,0.03);
  z-index: 9999;
  /* 适配底部安全区 */
  padding-bottom: env(safe-area-inset-bottom);
}

.tab-bar-inner {
  display: flex;
  justify-content: space-around;
  align-items: center;
  height: 60px; /* 锁定实际内容区域高度 */
}

.tab-item { display: flex; flex-direction: column; align-items: center; justify-content: center; padding: 8px; transition: color 0.2s; }
.tab-item.active { color: #eab308; }
.tab-item.inactive { color: #9ca3af; }
.tab-icon { font-size: 22px; margin-bottom: 4px; transition: transform 0.2s, opacity 0.2s; }
.tab-icon.active { transform: scale(1.1); opacity: 1; }
.tab-icon.inactive { opacity: 0.8; }
.tab-text { font-size: 10px; font-weight: bold; }